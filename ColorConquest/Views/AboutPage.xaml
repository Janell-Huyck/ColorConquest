<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ColorConquest.Views.AboutPage"
             Title="About">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">
            <Label Text="How to Play"
                   FontSize="26"
                   FontAttributes="Bold" />

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 12"
                    Padding="14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="1) Tap any tile to toggle it and its neighbors (up, down, left, right)."
                           LineBreakMode="WordWrap" />
                    <Label Text="2) Keep making moves until every tile is the same color."
                           LineBreakMode="WordWrap" />
                    <Label Text="3) Use Reset to retry the current puzzle, or New game for a fresh one."
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#F4F0FF, Dark=#2A2340}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Need help?"
                           FontSize="20"
                           FontAttributes="Bold" />
                    <Label Text="If you're frustrated or want a sure-fire solving strategy, watch this easy step-by-step guide."
                           LineBreakMode="WordWrap" />
                    <Button Text="Watch Solve Guide"
                            Clicked="OnSolveGuideTapped" />
                    <Label Text="Opens in your web browser: https://youtu.be/LnYCcUc4FIo?si=f1WIOlg7Z-9hUjY9"
                           FontSize="12"
                           Opacity="0.75"
                           LineBreakMode="CharacterWrap" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    StrokeShape="RoundRectangle 12"
                    Padding="14">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Settings"
                           FontSize="20"
                           FontAttributes="Bold" />
                    <Label Text="From Settings you can set difficulty (3×3, 5×5, or 9×9), tile colors, light or dark theme, and whether the move count and timer are shown."
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="1"
                     Color="{StaticResource Gray200}"
                     Margin="0,4,0,2" />

            <VerticalStackLayout Spacing="6">
                <Label Text="About"
                       FontSize="20"
                       FontAttributes="Bold" />
                <Label Text="Color Conquest is a quick logic puzzle designed for short breaks."
                       LineBreakMode="WordWrap" />
                <Label Text="Version 1.0"
                       Opacity="0.7" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
