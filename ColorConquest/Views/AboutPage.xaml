<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ColorConquest.Views.AboutPage"
             Title="About">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Instructions"
                   FontSize="22"
                   FontAttributes="Bold" />
            <Label Text="• Tap a square to toggle its color and the colors of the squares next to it (up, down, left, right)."
                   LineBreakMode="WordWrap" />
            <Label Text="• Your goal is to make every square on the grid the same color."
                   LineBreakMode="WordWrap" />
            <Label Text="• Use the Reset button to start the current puzzle over."
                   LineBreakMode="WordWrap" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,8,0,8" />

            <Label Text="Credits"
                   FontSize="22"
                   FontAttributes="Bold" />
            <Label Text="Color Conquest — a quick logic puzzle for short breaks."
                   LineBreakMode="WordWrap" />
            <Label Text="Version 1.0"
                   Opacity="0.7" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
