<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ColorConquest.Converters"
             x:Class="ColorConquest.Views.GamePage"
             x:Name="GamePageRoot"
             Title="Game">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsPrimaryToColorConverter x:Key="IsPrimaryToColor" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout Padding="20" Spacing="16">
        <Label Text="Color Conquest"
               FontSize="24"
               HorizontalOptions="Center" />

        <CollectionView x:Name="GameGrid"
                        ItemsSource="{Binding Cells}"
                        SelectionMode="None"
                        HorizontalOptions="Center"
                        VerticalScrollBarVisibility="Never"
                        HorizontalScrollBarVisibility="Never">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                            Padding="0"
                            WidthRequest="48"
                            HeightRequest="48"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                        <Border.BackgroundColor>
                            <Binding Path="IsPrimaryColor" Converter="{StaticResource IsPrimaryToColor}" />
                        </Border.BackgroundColor>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={x:Reference GamePageRoot}, Path=BindingContext.CellTappedCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Reset"
                Command="{Binding ResetCommand}"
                HorizontalOptions="Center" />
    </VerticalStackLayout>

</ContentPage>
