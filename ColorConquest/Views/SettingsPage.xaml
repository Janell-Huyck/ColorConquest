<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ColorConquest.Converters"
             x:Class="ColorConquest.Views.SettingsPage"
             Title="">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoardSizeToBoolConverter x:Key="BoardSizeToBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid x:Name="SettingsRootGrid">
        <ScrollView x:Name="SettingsScroll">
            <VerticalStackLayout Padding="20" Spacing="16">

                <Border x:Name="AppearanceSectionBorder"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="14">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="AppearanceHeaderLabel"
                               Text="Appearance"
                               FontSize="20"
                               FontAttributes="Bold" />

                        <Grid ColumnDefinitions="*,Auto"
                              VerticalOptions="Center">
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="DarkModeTitleLabel"
                                       Text="Dark mode"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label x:Name="DarkModeSubtitleLabel"
                                       Text="Turn on for dark colors; turn off for light."
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                                <Switch x:Name="ThemeSwitch"
                                    Grid.Column="1"
                                    VerticalOptions="Center"
                                    IsToggled="{Binding IsDarkTheme, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto"
                              VerticalOptions="Center">
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="ShowMoveTitleLabel"
                                       Text="Show move count"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label x:Name="ShowMoveSubtitleLabel"
                                       Text="Turn off to hide moves on the Game screen."
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                                <Switch x:Name="ShowMoveCountSwitch"
                                    Grid.Column="1"
                                    VerticalOptions="Center"
                                    IsToggled="{Binding ShowMoveCount, Mode=TwoWay}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto"
                              VerticalOptions="Center">
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="ShowGameTimerTitleLabel"
                                       Text="Show game timer"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label x:Name="ShowGameTimerSubtitleLabel"
                                       Text="Turn off to hide elapsed time on the Game screen."
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                                <Switch x:Name="ShowGameTimerSwitch"
                                    Grid.Column="1"
                                    VerticalOptions="Center"
                                    IsToggled="{Binding ShowGameTimer, Mode=TwoWay}" />
                        </Grid>

                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="TileColorsTitleLabel"
                                   Text="Tile colors"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Label x:Name="TileColorsSubtitleLabel"
                                   Text="Tap a row to open the palette (6 dark + 6 light)." />

                            <Label x:Name="PrimarySectionLabel"
                                   Text="Primary tile"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10"
                                  VerticalOptions="Center">
                                <Border x:Name="PrimaryTileStrokeBorder"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        StrokeThickness="1"
                                        VerticalOptions="Center">
                                    <BoxView x:Name="PrimaryTilePreview" />
                                </Border>
                                <Border x:Name="PrimaryPickerRowBorder"
                                        Grid.Column="1"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,10">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetPrimaryColorCommand}" CommandParameter="{Binding SelectedPrimaryColor}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto">
                                             <Label x:Name="PrimaryColorNameLabel"
                                                 Text="{Binding SelectedPrimaryColor.Name}"
                                                 VerticalOptions="Center"
                                                 LineBreakMode="TailTruncation" />
                                        <Label x:Name="PrimaryChevronLabel"
                                               Grid.Column="1"
                                               Text="▼"
                                               FontSize="14"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <Label x:Name="SecondarySectionLabel"
                                   Text="Secondary tile"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10"
                                  VerticalOptions="Center">
                                <Border x:Name="SecondaryTileStrokeBorder"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        StrokeThickness="1"
                                        VerticalOptions="Center">
                                    <BoxView x:Name="SecondaryTilePreview" />
                                </Border>
                                <Border x:Name="SecondaryPickerRowBorder"
                                        Grid.Column="1"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,10">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetSecondaryColorCommand}" CommandParameter="{Binding SelectedSecondaryColor}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto">
                                             <Label x:Name="SecondaryColorNameLabel"
                                                 Text="{Binding SelectedSecondaryColor.Name}"
                                                 VerticalOptions="Center"
                                                 LineBreakMode="TailTruncation" />
                                        <Label x:Name="SecondaryChevronLabel"
                                               Grid.Column="1"
                                               Text="▼"
                                               FontSize="14"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="GameplaySectionBorder"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="GameplayHeaderLabel"
                               Text="Gameplay"
                               FontSize="20"
                               FontAttributes="Bold" />
                        <Label x:Name="BoardSizeTitleLabel"
                               Text="Board Size"
                               FontSize="16"
                               FontAttributes="Bold" />
                        <Label x:Name="BoardSizeSubtitleLabel"
                               Text="Tap a row to choose. Easy 3×3, Medium 5×5, Hard 9×9. Applies when you open the Game screen."
                               LineBreakMode="WordWrap" />
                        <CollectionView ItemsSource="{Binding BoardSizeOptions}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12,10">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding BindingContext.SetBoardSizeCommand, Source={x:Reference Name=SettingsRootGrid}}" CommandParameter="{Binding Size}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding Label}" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="1" Text="✓" FontSize="16" VerticalOptions="Center"
                                                   IsVisible="{Binding BindingContext.SelectedBoardSize, Source={x:Reference Name=SettingsRootGrid}, Converter={StaticResource BoardSizeToBoolConverter}, ConverterParameter={Binding Size}}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="FooterHintLabel"
                       Text="Tip: change tile colors under Appearance."
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Modal color palette (Picker is unreliable on some Mac Catalyst builds). -->
        <!-- Scrim is the overlay Grid's BackgroundColor — BoxView scrim often fails to paint/fill on Mac Catalyst. -->
        <Grid x:Name="ColorPaletteOverlay"
              IsVisible="False"
              InputTransparent="False"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <!-- Palette overlay tap logic should be handled by ViewModel/UI state. Gesture removed for MVVM compliance. -->

            <Border x:Name="PaletteModalBorder"
                    Margin="24"
                    Padding="16"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="420">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="PaletteTitleLabel"
                           FontSize="18"
                           FontAttributes="Bold"
                           Text="Choose a color" />
                    <Label x:Name="PaletteInstructionLabel"
                           Text="Tap a swatch. Dark colors are in the first row; light colors follow."
                           FontSize="13"
                           LineBreakMode="WordWrap" />
                    <Grid x:Name="PaletteSwatchesGrid"
                          ColumnSpacing="8"
                          RowSpacing="8" />
                        <Button Text="Cancel" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
