<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ColorConquest.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ColorConquest.Views"
    Title="Color Conquest">

    <FlyoutItem Title="Home" Route="HomePage" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent
            ContentTemplate="{DataTemplate views:HomePage}" />
    </FlyoutItem>
    <FlyoutItem Title="Game" Route="GamePage" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent
            ContentTemplate="{DataTemplate views:GamePage}" />
    </FlyoutItem>
    <FlyoutItem Title="Settings" Route="SettingsPage" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </FlyoutItem>
    <FlyoutItem Title="About" Route="AboutPage" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent
            ContentTemplate="{DataTemplate views:AboutPage}" />
    </FlyoutItem>

</Shell>
